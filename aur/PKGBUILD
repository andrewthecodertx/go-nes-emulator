# Maintainer: Your Name <your.email@example.com>
pkgname=nes-emulator-git
pkgver=r50.b415ee4
pkgrel=1
pkgdesc="A Nintendo Entertainment System emulator written in Go"
arch=('x86_64')
url="https://github.com/andrewthecodertx/go-nes-emulator"
license=('MIT')
depends=('sdl2')
makedepends=('go' 'git')
provides=('nes-emulator')
conflicts=('nes-emulator')
source=("${pkgname}::git+https://github.com/andrewthecodertx/go-nes-emulator.git")
sha256sums=('SKIP')

pkgver() {
    cd "$pkgname"
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
    cd "$pkgname"
    export CGO_CFLAGS="${CFLAGS}"
    export CGO_CXXFLAGS="${CXXFLAGS}"
    export CGO_LDFLAGS="${LDFLAGS}"
    export GOFLAGS="-buildmode=pie -trimpath -mod=readonly -modcacherw"
    go build -ldflags="-s -w -linkmode=external" -o nes-emulator ./cmd/sdl-display
}

package() {
    cd "$pkgname"
    install -Dm755 nes-emulator "$pkgdir/usr/bin/nes-emulator"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
